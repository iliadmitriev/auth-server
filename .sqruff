[sqruff]
dialect = postgres
max_line_length = 256
rules = all

[sqruff:indentation]
tab_space_size = 4
indent_unit = space
indented_using_on = true
indented_on_contents = true
allow_implicit_indents = true
indented_joins = true
indented_ctes = true

[sqruff:layout:type:column_definition]
spacing_before = align
align_within = statement
align_scope = file

[sqruff:layout:type:column_constraint_segment]
spacing_before = align
align_within = statement
align_scope = file

[sqruff:layout:type:data_type]
spacing_before = align
align_within = statement
align_scope = file
